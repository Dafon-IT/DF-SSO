# Microsoft Azure AD 設定
# 請在 Azure Portal > App registrations 中取得以下資訊

# Application (client) ID
AZURE_CLIENT_ID=your-client-id-here

# Client Secret (在 Certificates & secrets 中建立)
AZURE_CLIENT_SECRET=your-client-secret-here

# Directory (tenant) ID
AZURE_TENANT_ID=your-tenant-id-here

# OAuth Redirect URI (需與 Azure AD 中設定一致)
# 格式: https://{your-domain}/api/auth/microsoft/redirect
AZURE_REDIRECT_URI=https://your-domain.com/api/auth/microsoft/redirect

# 登入成功後重導向的頁面路徑
ROPC_REDIRECT_URL=/
