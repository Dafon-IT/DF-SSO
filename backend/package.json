{
  "name": "df-sso-backend",
  "version": "1.0.0",
  "description": "DF SSO Backend - Microsoft Azure AD Login",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate:up:dev": "node-pg-migrate -m migrations/dev up",
    "migrate:down:dev": "node-pg-migrate -m migrations/dev down",
    "migrate:create:dev": "node-pg-migrate -m migrations/dev create",
    "migrate:up:prod": "node-pg-migrate -m migrations/prod up",
    "migrate:down:prod": "node-pg-migrate -m migrations/prod down",
    "migrate:create:prod": "node-pg-migrate -m migrations/prod create"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.2",
    "connect-redis": "^7.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "seq-logging": "^2.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
