# ============================================
# DF-SSO Backend 環境變數
# 複製為 .env 並填入實際值
# 標記 [必填] 的變數啟動時會驗證
# ============================================

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Session [必填]
SESSION_SECRET=<隨機產生 32+ 字元的密鑰>

# JWT [必填]
JWT_SECRET=<隨機產生 32+ 字元的密鑰>
JWT_EXPIRES_IN=24h

# Microsoft Azure AD [必填]
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=<Azure AD Client Secret>
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_REDIRECT_URI=http://localhost:3001/api/auth/microsoft/redirect

# Login redirect（SSO Dashboard 登入後導向）
ROPC_REDIRECT_URL=http://localhost:3000/dashboard

# PostgreSQL [必填]
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=SSO-v1
PG_SCHEMA=public
PG_USER=postgres
PG_PASSWORD=<PostgreSQL 密碼>

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=15

# ERP API（選填，未設定則登入紀錄狀態為 erp_not_found）
ERP_API_LOGIN_URL=http://localhost:3333/api/auth/login
ERP_API_SEARCH_URL=http://localhost:3333/api/etl/employee/search
ERP_API_ACCOUNT=<ERP 帳號>
ERP_API_PASSWORD=<ERP 密碼>
