# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# 允許的 CORS origins（逗號分隔），客戶端 App 的 origin
ALLOWED_ORIGINS=http://localhost:3100,http://localhost:3200

# Session
SESSION_SECRET=your-session-secret-here

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=24h

# Microsoft Azure AD
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_REDIRECT_URI=http://localhost:3001/api/auth/microsoft/redirect

# Login redirect
ROPC_REDIRECT_URL=http://localhost:3000/dashboard

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=SSO-v1
PG_SCHEMA=public
PG_USER=postgres
PG_PASSWORD=your-pg-password-here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=15
